# Database (asyncpg requires postgresql+asyncpg:// scheme)
DATABASE_URL=postgresql+asyncpg://cashflow:cashflow@localhost:5432/cashflow

# JWT – REQUIRED: change in production, min 32 characters
JWT_SECRET_KEY=change-me-in-production-min-32-chars
JWT_EXPIRE_MINUTES=60

# App
FRONTEND_URL=http://localhost:5173
ENV=development

# -----------------------------------------------------------------------------
# SMTP Email Configuration (Required for email features)
# -----------------------------------------------------------------------------
SMTP_ENABLED=false
SMTP_HOST=mail-eu.smtp2go.com
SMTP_PORT=2525
SMTP_SECURITY=starttls
SMTP_USERNAME=noreply@goodguys.ai
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@goodguys.ai
SMTP_FROM_NAME=CashFlow
SMTP_REPLY_TO=noreply@goodguys.ai

# Invitation
INVITATION_EXPIRE_DAYS=7

# Dev Seed – only for local development, never set in production
SEED_ADMIN_EMAIL=admin@local.dev
SEED_ADMIN_PASSWORD=
